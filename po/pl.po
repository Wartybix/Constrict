#: src/constrict_utils.py:821
msgid ""
"Constrict: Could not read input file. Was it moved or deleted before "
"compression?"
msgstr ""
"Ścisk: Nie można odczytać pliku wejściowego. Czy został przeniesiony lub "
"usunięty przed skompresowaniem?"

#: src/constrict_utils.py:845
msgid ""
"Constrict: Could not retrieve video properties. Source video may be missing "
"or corrupted."
msgstr ""
"Ścisk: Nie można odczytać właściwości wideo. Może brakować pliku źródłowego "
"lub jest uszkodzony."

#. This should never happen if a unique file name has been passed to
#. this function as file_output.
#: src/constrict_utils.py:852
msgid ""
"Constrict: Could not create exported file. A file with the reserved name "
"already exists."
msgstr ""
"Ścisk: Nie można utworzyć wyeksportowanego pliku. Plik o wybranej nazwie już "
"istnieje."

#: src/constrict_utils.py:854
msgid ""
"Constrict: Could not create exported file. There are insufficient "
"permissions to create a file at the requested export path."
msgstr ""
"Ścisk: Nie można utworzyć wyeksportowanego pliku. Brak wystarczających uprawnień "
"do utworzenia pliku w wybranym katalogu."

#: src/constrict_utils.py:921
msgid ""
"Constrict: Video bitrate got too low (<5 kbps). The target size may be too "
"low for this file."
msgstr ""
"Ścisk: Przepływność wideo jest zbyt niska (<5 kb/s). Wyznaczony rozmiar może "
"być zbyt mały dla tego pliku."

#: src/constrict_utils.py:966
msgid ""
"Constrict: Cannot read output file. Was it moved or deleted mid-compression?"
msgstr ""
"Ścisk: Nie można odczytać pliku wyjściowego. Czy został przeniesiony lub "
"usunięty w czasie kompresowania?"

